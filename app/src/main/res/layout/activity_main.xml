<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_background"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_console_title"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/player_console_subtitle"
                android:textColor="#F5F0FF"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />

        <TextView
            style="@style/SectionLabel"
            android:text="@string/connection_section" />

        <EditText
            android:id="@+id/hostInput"
            style="@style/FormInput"
            android:hint="@string/host_hint"
            android:inputType="textUri"
            android:singleLine="true"
            android:text="@string/default_master_host" />

        <EditText
            android:id="@+id/portInput"
            style="@style/FormInput"
            android:hint="@string/port_hint"
            android:inputType="number"
            android:singleLine="true"
            android:text="@string/default_master_port" />

        <EditText
            android:id="@+id/playerIdInput"
            style="@style/FormInput"
            android:hint="@string/player_id_hint"
            android:inputType="text"
            android:singleLine="true" />

        <TextView
            style="@style/SectionLabel"
            android:text="@string/balance_section" />

        <EditText
            android:id="@+id/balanceAmountInput"
            style="@style/FormInput"
            android:hint="@string/balance_amount_hint"
            android:inputType="numberDecimal"
            android:singleLine="true" />

        <Button
            android:id="@+id/addBalanceButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/add_balance_button" />

        <Button
            android:id="@+id/showPlayerStatsButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="@string/show_player_stats_button" />

        <LinearLayout
            android:id="@+id/playerStatsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/result_panel_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/playerStatsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/playerStatsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>

        <TextView
            style="@style/SectionLabel"
            android:text="@string/search_section" />

        <Button
            android:id="@+id/showAllGamesButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            android:text="@string/show_all_games_button" />

        <EditText
            android:id="@+id/providerInput"
            style="@style/FormInput"
            android:hint="@string/provider_hint"
            android:inputType="text"
            android:singleLine="true" />

        <Spinner
            android:id="@+id/riskSpinner"
            style="@style/FormSpinner"
            android:entries="@array/risk_filter_options" />

        <Spinner
            android:id="@+id/betCategorySpinner"
            style="@style/FormSpinner"
            android:entries="@array/bet_category_filter_options" />

        <Spinner
            android:id="@+id/starsSpinner"
            style="@style/FormSpinner"
            android:entries="@array/star_filter_options" />

        <Button
            android:id="@+id/searchButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="@string/search_button" />

        <TextView
            style="@style/SectionLabel"
            android:text="@string/results_section" />

        <LinearLayout
            android:id="@+id/gamesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/result_panel_background"
            android:padding="16dp"
            android:text="@string/no_results"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

    </LinearLayout>
</ScrollView>
